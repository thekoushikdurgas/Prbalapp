  "onboarding": {
    "title_1": "எந்த நேரத்திலும், எங்கும் உதவி பெறுங்கள்!",
    "title_2": "பயன்படுத்த எளிதானது",
    "title_3": "பாதுகாப்பான & நம்பகமான",
    "title_4": "உங்கள் விதிமுறைகளில் சம்பாதிக்கவும்",
    "title_5": "ஸ்மார்ட் விலைக்கூறல்",
    "title_6": "உங்களுக்கு சிறந்த பொருத்தத்தைக் கண்டறியவும்",
    "title_7": "அழகான, உள்ளுணர்வு வடிவமைப்பு",
    "title_8": "நம்பகமான & சரிபார்க்கப்பட்ட நிபுணர்கள்",
    "description_1": "நம்பகமான சேவைகள் முதல் திறமையான பணியாளர்கள் வரை — உங்களுக்குத் தேவையானதை, தேவைப்படும் போது பெறுங்கள்",
    "description_2": "சிறந்த பயனர் அனுபவத்திற்கான எளிமையான மற்றும் உள்ளுணர்வு இடைமுகம்",
    "description_3": "உங்கள் தரவு எங்களுடன் பாதுகாப்பானது",
    "description_4": "உங்கள் மணிநேர விகிதங்களை அமைக்கவும் மற்றும் உங்கள் வருமானத்தை அதிகப்படுத்த AI உதவியைப் பெறுங்கள்",
    "description_5": "உங்கள் திறன்களின் அடிப்படையில் தனிப்பயனாக்கப்பட்ட சலுகைகளை உருவாக்கவும், AI சந்தை போக்குகளின் அடிப்படையில் நியாயமான ஊதியத்தை பரிந்துரைக்கும்",
    "description_6": "எங்கள் ஸ்மார்ட் அல்காரிதம் உங்கள் விருப்பங்களைக் கற்றுக்கொண்டு, வேலைகள் அல்லது சேவைகளுக்கான சிறந்த பொருத்தங்களுடன் உங்களை இணைக்கிறது",
    "description_7": "தெளிவான படங்கள் மற்றும் எளிய தொடர்புகளுடன் கூடிய மினிமலிஸ்டிக் இடைமுகத்தை அனுபவிக்கவும்",
    "description_8": "உங்கள் மன அமைதிக்காக ஒவ்வொரு நிபுணரும் முழுமையான பின்னணி சரிபார்ப்பு மூலம் செல்கிறார்"
